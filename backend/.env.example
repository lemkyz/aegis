# Generate a local fingerprint key with:
# python -c 'import secrets; print(secrets.token_urlsafe(48))'
AEGIS_FINGERPRINT_KEY=replace-with-a-random-local-value

# Model provider configuration
NVIDIA_API_KEY=replace-with-your-provider-key
NVIDIA_BASE_URL=replace-with-your-provider-base-url
NVIDIA_MODEL=replace-with-your-model-name

# Model request behavior
AI_MAX_RETRIES=3
AI_REQUEST_TIMEOUT_SECONDS=60
