{
  "name": "aegis-security",
  "displayName": "Aegis Security",
  "description": "Evidence-first AI security engineering for VS Code.",
  "version": "0.1.0",
  "publisher": "aegis",
  "private": true,
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc --watch -p ./"
  },
  "contributes": {
    "commands": [
      {
        "command": "aegis.fastScanSelectedCode",
        "title": "Aegis: Fast Scan Selected Code",
        "category": "Aegis"
      },
      {
        "command": "aegis.fastScanCurrentFile",
        "title": "Aegis: Fast Scan Current File",
        "category": "Aegis"
      },
      {
        "command": "aegis.deepAnalyzeSelectedCode",
        "title": "Aegis: Deep Analysis Selected Code",
        "category": "Aegis"
      },
      {
        "command": "aegis.applySecureFix",
        "title": "Aegis: Apply Secure Fix",
        "category": "Aegis"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "aegis.fastScanSelectedCode",
          "when": "editorHasSelection",
          "group": "aegis@1"
        },
        {
          "command": "aegis.fastScanCurrentFile",
          "when": "editorTextFocus",
          "group": "aegis@2"
        },
        {
          "command": "aegis.deepAnalyzeSelectedCode",
          "when": "editorHasSelection",
          "group": "aegis@3"
        },
        {
          "command": "aegis.applySecureFix",
          "when": "editorHasSelection",
          "group": "aegis@4"
        }
      ]
    },
    "configuration": {
      "title": "Aegis",
      "properties": {
        "aegis.backendUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8000",
          "description": "Address of the local Aegis backend."
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@types/vscode": "^1.100.0",
    "typescript": "^5.8.0"
  }
}
